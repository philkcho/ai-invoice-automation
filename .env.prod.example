# ============================================================
# AI Invoice Automation — Production Environment Variables
# ============================================================
# cp .env.prod.example .env.prod  후 실제 값을 채워 넣으세요.
# ============================================================

# ── 환경 ──
ENVIRONMENT=production
DEBUG=false

# ── 도메인 (Caddy 자동 SSL) ──
DOMAIN=ai-invoice.araverus.com

# ── Supabase PostgreSQL ──
# Dashboard > Settings > Database > Connection string
# Pooler (Transaction mode, 포트 6543) — 런타임용
DATABASE_URL=postgresql+asyncpg://postgres.xxxx:YOUR_PASSWORD@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres?prepared_statement_cache_size=0
DATABASE_URL_SYNC=postgresql://postgres.xxxx:YOUR_PASSWORD@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres
# ⚠️ Alembic 마이그레이션 시에는 Direct connection (포트 5432) 사용:
# DATABASE_URL=postgresql+asyncpg://postgres.xxxx:YOUR_PASSWORD@db.xxxx.supabase.co:5432/postgres

# ── Redis / Celery ──
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ── JWT / 보안 ──
# 새 키 생성: openssl rand -hex 32
SECRET_KEY=REPLACE_WITH_openssl_rand_hex_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── 암호화 (ACH) ──
# 새 키 생성: openssl rand -hex 32
ENCRYPTION_KEY=REPLACE_WITH_openssl_rand_hex_32

# ── Claude API (미설정 시 OCR mock 사용) ──
ANTHROPIC_API_KEY=sk-ant-xxxxx

# ── Google Document AI ──
GOOGLE_PROJECT_ID=your-google-project-id
GOOGLE_LOCATION=us
GOOGLE_PROCESSOR_ID=your-processor-id
GOOGLE_APPLICATION_CREDENTIALS=/app/credentials/google-sa-key.json

# ── Gmail ──
GMAIL_CLIENT_ID=your-gmail-client-id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your-gmail-client-secret
GMAIL_REDIRECT_URI=https://ai-invoice.araverus.com/settings/email/callback

# ── SMTP ──
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# ── CORS ──
CORS_ORIGINS=https://ai-invoice.araverus.com

# ── Cookie (HTTPS 필수) ──
COOKIE_SECURE=true
COOKIE_DOMAIN=ai-invoice.araverus.com
COOKIE_SAMESITE=lax

# ── Frontend URL ──
# ⚠️ /api 붙이면 안 됨! 프론트엔드가 baseURL + /api/v1/... 형태로 호출
FRONTEND_URL=https://ai-invoice.araverus.com
NEXT_PUBLIC_API_URL=https://ai-invoice.araverus.com

# ── Rate Limiting ──
RATE_LIMIT_IP_PER_MIN=60
RATE_LIMIT_COMPANY_PER_MIN=500
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# ── Stripe ──
STRIPE_SECRET_KEY=sk_live_xxxxx
STRIPE_PUBLISHABLE_KEY=pk_live_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxxxx

# ── Sentry (에러 추적, 선택) ──
SENTRY_DSN=

# ── Telegram Alerts (선택) ──
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Flower 모니터링 인증 ──
FLOWER_USER=admin
FLOWER_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# ── Backup ──
BACKUP_DIR=/backups
