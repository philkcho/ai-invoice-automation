ENVIRONMENT=development
DEBUG=true
POSTGRES_USER=invoice_user
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=invoice_db
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://invoice_user:change_me_in_production@db:5432/invoice_db
DATABASE_URL_SYNC=postgresql://invoice_user:change_me_in_production@db:5432/invoice_db
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
# ⚠️ 반드시 새로운 키로 교체할 것! (예: openssl rand -hex 32)
SECRET_KEY=REPLACE_WITH_RANDOM_HEX_64
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
# ⚠️ 반드시 새로운 키로 교체할 것! (예: openssl rand -hex 32)
ENCRYPTION_KEY=REPLACE_WITH_RANDOM_HEX_64
ANTHROPIC_API_KEY=your-anthropic-api-key

# Google Document AI (Invoice Parser)
GOOGLE_PROJECT_ID=your-google-project-id
GOOGLE_LOCATION=us
GOOGLE_PROCESSOR_ID=your-processor-id
GOOGLE_APPLICATION_CREDENTIALS=/app/credentials/google-sa-key.json
GMAIL_CLIENT_ID=your-gmail-client-id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your-gmail-client-secret
GMAIL_REDIRECT_URI=http://localhost:3000/settings/email/callback
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
CORS_ORIGINS=http://localhost:3000
RATE_LIMIT_IP_PER_MIN=100
RATE_LIMIT_COMPANY_PER_MIN=1000
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15
NEXT_PUBLIC_API_URL=http://localhost:8000
